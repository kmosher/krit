    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-query": "^5.96.2",
    "@uiw/react-codemirror": "^4.25.10"
  },
  "devDependencies": {
    "@pierre/diffs": "^1.2.12",
    "@types/node": "^25.5.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^1.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
